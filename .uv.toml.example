# Example uv global configuration
# Copy this to ~/.config/uv/uv.toml to configure uv globally for all projects
#
# This allows you to install packages from GitLab Package Registry
# without configuring each project individually

# Add GitLab Package Registry as a named index
# Group 591 is the innersource group
[[index]]
name = "gitlab-innersource"
url = "https://sgts.gitlab-dedicated.com/api/v4/groups/591/-/packages/pypi/simple"

# IMPORTANT: Authentication
# DO NOT put credentials in this file. Use environment variables instead.
# Add these to your shell profile (~/.bashrc, ~/.zshrc, etc.):
#
# export UV_INDEX_GITLAB_INNERSOURCE_USERNAME=my-token
# export UV_INDEX_GITLAB_INNERSOURCE_PASSWORD=$GITLAB_TOKEN
#
# The environment variable name is based on the index NAME (gitlab-innersource),
# not the hostname. The name is uppercased with non-alphanumeric characters
# replaced by underscores: gitlab-innersource -> GITLAB_INNERSOURCE
